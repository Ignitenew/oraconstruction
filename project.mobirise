          "_name": "features07",
          "_sourceTheme": "discretem5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features7\" group=\"Features\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"7\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"7\" condition=\"fullScreen == false\">\n        <header>Show/Hide</header>\n        <input type=\"range\" inline name=\"cards\" title=\"Cards\" min=\"1\" max=\"3\" value=\"3\" step=\"1\">\n        <input type=\"checkbox\" title=\"Main Title\" name=\"showmainTitle\">\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubitle\">\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\">\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@THEME_PATH@/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#e1e7e4\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@THEME_PATH@/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#fafafa\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.1\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div class mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row align-left justify-content-center\">\n            <div class=\"col-12\">\n\n\n                <h2 class=\"mbr-section-maintitle mbr-fonts-style pb-5\" mbr-if=\"showmainTitle\" data-app-selector=\".mbr-section-maintitle\" mbr-theme-style=\"display-2\"><b>Our Features</b></h2>\n            </div>\n\n            <div class=\"col-12 col-lg-4\">\n                <div class=\"card-wrapper\">\n                    <div class=\"align-wrapper\" mbr-if=\"showSubitle\">\n                        <div class=\"subtitle-wrap\">\n                            <h2 class=\"mbr-section-subtitle2 mbr-fonts-style\" data-app-selector=\".mbr-section-subtitle2, .align-wrapper\" mbr-theme-style=\"display-4\" mbr-if=\"showSubitle\"><b>\n\n                                    Step 1</b></h2>\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-right mobi-mbri\"></span>\n                            <h2 class=\"mbr-section-subtitle mbr-fonts-style\" data-app-selector=\".mbr-section-subtitle, .align-wrapper\" mbr-theme-style=\"display-4\" mbr-if=\"showSubitle\"><b>1 weeks</b></h2>\n                        </div>\n                    </div>\n                    <div class=\"item-img\">\n                        <iframe src=\"https://www.accuweather.com/en/us/syosset/11791/weather-forecast/2146297\"name=\"Ora Construction - Home Remodeling, Masonry & Landscape Design\" scrolling=\"yes\" width=\"400px\" height=\"600px\"></iframe>\n                    </div>\n                    <h1 class=\"mbr-section-title mbr-fonts-style mb-3\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-4\" mbr-if=\"showTitle\">Syosset, NY\n<div>Weather</div></h1>\n\n                    <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\">\n                        Lorem ipsum dolor sit amet consect adipiscing elit. Integer libero\n                        commodo ante eleifend.</p>\n                    <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn mt-3\" mbr-if=\"showButtons\"><a class=\"btn btn-secondary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">Create\n                            Website</a></div>\n                </div>\n            </div>\n\n            <div class=\"col-12 col-lg-4\" mbr-if=\"cards > 1\">\n                <div class=\"card-wrapper\">\n                    <div class=\"align-wrapper\" mbr-if=\"showSubitle\">\n                        <div class=\"subtitle-wrap\">\n                            <h2 class=\"mbr-section-subtitle2 mbr-fonts-style\" data-app-selector=\".mbr-section-subtitle2, .align-wrapper\" mbr-theme-style=\"display-4\" mbr-if=\"showSubitle\"><b>\n\n                                    Step 2</b></h2>\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-right mobi-mbri\"></span>\n                            <h2 class=\"mbr-section-subtitle mbr-fonts-style\" data-app-selector=\".mbr-section-subtitle, .align-wrapper\" mbr-theme-style=\"display-4\" mbr-if=\"showSubitle\"><b>2 weeks</b></h2>\n                        </div>\n                    </div>\n                    <div class=\"item-img\">\n                        <iframe src=\"https://en.wikipedia.org/wiki/Syosset,_New_York\"name=\"Ora Construction - Home Remodeling, Masonry & Landscape Design\" scrolling=\"yes\" width=\"400px\" height=\"600px\"></iframe>\n                    </div>\n                    <h1 class=\"mbr-section-title mbr-fonts-style mb-3\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-4\" mbr-if=\"showTitle\">Syosset, New York</h1>\n\n                    <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\">\n                        Lorem ipsum dolor sit amet consect adipiscing elit. Integer libero commodo ante eleifend.</p>\n                    <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn mt-3\" mbr-if=\"showButtons\"><a class=\"btn btn-secondary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">Create\n                            Website</a></div>\n                </div>\n            </div>\n\n            <div class=\"col-12 col-lg-4\" mbr-if=\"cards > 2\">\n                <div class=\"card-wrapper\">\n                    <div class=\"align-wrapper\" mbr-if=\"showSubitle\">\n                        <div class=\"subtitle-wrap\">\n                            <h2 class=\"mbr-section-subtitle2 mbr-fonts-style\" data-app-selector=\".mbr-section-subtitle2, .align-wrapper\" mbr-theme-style=\"display-4\" mbr-if=\"showSubitle\"><b>\n\n                                    Step 3</b></h2>\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-right mobi-mbri\"></span>\n                            <h2 class=\"mbr-section-subtitle mbr-fonts-style\" data-app-selector=\".mbr-section-subtitle, .align-wrapper\" mbr-theme-style=\"display-4\" mbr-if=\"showSubitle\"><b>3 weeks</b></h2>\n                        </div>\n                    </div>\n                    <div class=\"item-img\">\n                        <iframe src=\"https://en.wikipedia.org/wiki/Construction\"name=\"Ora Construction - Home Remodeling, Masonry & Landscape Design\" scrolling=\"yes\" width=\"400px\" height=\"600px\"></iframe>\n                    </div>\n                    <h1 class=\"mbr-section-title mbr-fonts-style mb-3\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-4\" mbr-if=\"showTitle\">Construction\n<div>Service</div></h1>\n\n                    <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\">\n                        Lorem ipsum dolor sit amet consect adipiscing elit. Integer libero commodo ante eleifend.</p>\n                    <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn mt-3\" mbr-if=\"showButtons\"><a class=\"btn btn-secondary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">Create\n                            Website</a></div>\n                </div>\n            </div>\n\n        </div>\n    </div>\n</section>",
