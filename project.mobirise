              "background": "@primaryColor",
              "flex-direction": "row",
              "width": "fit-content",
              "align-items": "center",
              "margin-bottom": "2rem",
              ".mbr-iconfont": {
                "padding": "0 15px",
                "padding-bottom": "8px",
                "margin": "0",
                "color": "@secondaryColor",
