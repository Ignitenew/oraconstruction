          "_name": "features04",
          "_sourceTheme": "discretem5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features4\" group=\"Features\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"7\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"7\" condition=\"fullScreen == false\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\">\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <input type=\"checkbox\" title=\"Card Subtitle\" name=\"showcardSubitle\">\n        <input type=\"checkbox\" title=\"Card Text\" name=\"showcardText\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@THEME_PATH@/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#e1e7e4\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@THEME_PATH@/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#fafafa\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.1\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n    <div class mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row  align-left {{contentAlign}}\">\n            <div class=\"col-12 col-lg-6 pb-5\">\n                <div class=\"align-wrapper\" mbr-if=\"showSubitle\">\n                    <div class=\"subtitle-wrap\">\n                        <span mbr-icon class=\"mbr-iconfont mobi-mbri-globe-2 mobi-mbri\"></span>\n                        <h2 class=\"mbr-section-subtitle mbr-fonts-style\" data-app-selector=\".mbr-section-subtitle, .align-wrapper\" mbr-theme-style=\"display-4\" mbr-if=\"showSubitle\"><b>Address</b></h2>\n                    </div>\n                </div>\n                <h1 class=\"mbr-section-title mbr-fonts-style mb-3\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\"><b>Grow Up</b></h1>\n\n                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\">Ora Construction - Home Remodeling, Masonry &amp; Landscape Design\n<br>24 David Drive, Syosset,\n<br>NY 11791\n<br>\n<br><b><u>Phone Number:\n</u></b><br>(516) 697-7680\n<br>\n<br><b><u>Website:\n</u></b><br><a href=\"https://ora-construction.com/\" class=\"text-primary\">https://ora-construction.com/</a></p>\n                <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn mt-3\" mbr-if=\"showButtons\"><a class=\"btn btn-secondary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">Create\n                        Website</a></div>\n            </div>\n            <div class=\"col-12 col-lg-6\">\n                <div class=\"card-wrapper\">\n                    <div class=\"align-wrapper2\" mbr-if=\"showcardSubitle\">\n                        <div class=\"subtitle-wrap2\">\n                            <h2 class=\"mbr-section-subtitle3 mbr-fonts-style\" data-app-selector=\".mbr-section-subtitle3, .align-wrapper2\" mbr-theme-style=\"display-4\" mbr-if=\"showcardSubitle\"><b>\n\n                                    Step 1</b></h2>\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-right mobi-mbri\"></span>\n                            <h2 class=\"mbr-section-subtitle2 mbr-fonts-style\" data-app-selector=\".mbr-section-subtitle2, .align-wrapper2\" mbr-theme-style=\"display-4\" mbr-if=\"showcardSubitle\"><b>\n\n                                    1-2 weeks</b></h2>\n                        </div>\n                    </div>\n                    <h1 class=\"mbr-section-cardtitle mbr-fonts-style mb-3\" data-app-selector=\".mbr-section-cardtitle\" mbr-theme-style=\"display-5\"><b><iframe src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3188.7878633363084!2d-73.5098697!3d40.812250399999996!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c281751430800f%3A0x8b31bcceb8203724!2sOra%20Construction%20-%20Home%20Remodeling%2C%20Masonry%20%26%20Landscape%20Design!5e1!3m2!1sen!2sro!4v1773819835510!5m2!1sen!2sro\" width=\"600\" height=\"450\" style=\"border:0;\" allowfullscreen loading=\"lazy\" referrerpolicy=\"no-referrer-when-downgrade\"></iframe></b></h1>\n                    <p class=\"mbr-cardtext mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showcardText\" data-app-selector=\".mbr-cardtext\">\n                        Lorem ipsum dolor sit amet consectetur adipiscing elit. Morbi a elit ante. Integer libero\n                        commodo eleifend.</p>\n                </div>\n            </div>\n\n        </div>\n    </div>\n</section>",
          "_PHPplaceholders": [],
          "_JSplaceholders": [],
          "_cid": "vengTASH0k",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {},
          "_anchor": "features04-z"
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "background-color": "@bgColor",
            "& when (@reverseContent)": {
              ".row": {
                "flex-direction": "row-reverse"
              }
            },
            ".mbr-text": {
              "color": "#fafaf9"
            },
            ".mbr-section-title": {
              "color": "#ffffff",
              "text-align": "center"
            },
            "p": {
              "opacity": "0.7"
            },
            ".wrapper": {
              "background": "@bgCard",
              "padding": "4rem",
              "border-radius": "2rem",
              "@media (max-width: 992px)": {
                "margin-bottom": "2rem"
              },
              "@media (max-width: 767px)": {
                "padding": "2rem 1rem"
              }
            }
          },
          "_name": "features01",
          "_sourceTheme": "discretem5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features1\" group=\"Features\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"checkbox\" name=\"reverseContent\" title=\"Reverse\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <header>Show/Hide</header>\n        <input type=\"range\" inline title=\"Card\" name=\"card\" min=\"1\" max=\"2\" step=\"1\" value=\"2\">\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <header>Color</header>\n        <input type=\"color\" title=\"Card\" name=\"bgCard\" value=\"#033b25\">\n\n        <header>Background</header>\n        <input type=\"color\" title=\"Color\" name=\"bgColor\" value=\"#04492e\">\n    </mbr-parameters>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row align-left justify-content-center\">\n\n            <div class=\"col-12 col-lg-6\">\n                <div class=\"wrapper\">\n                    <h5 class=\"mbr-section-title mbr-fonts-style mb-4\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-5\"><b>Integrating Structural Features And Durable Materials</b></h5>\n                    <p class=\"mbr-text mbr-fonts-style\" data-app-selector=\".mbr-text\" mbr-theme-style=\"display-7\">Functionality is not just about layout—it is also about choosing materials and structural elements that stand the test of time. Builders must evaluate durability, maintenance requirements, and long-term performance when selecting construction materials.<br>\n<br>For example, quality masonry work plays a significant role in both structural stability and visual appeal. A skilled <a href=\"https://ora-construction.com/\" class=\"text-primary\"><b><u>construction company</u></b></a> masonry specialist may design features such as stone facades, structural retaining walls, or decorative elements that enhance the home’s character.<br>\n<br>Similarly, a reliable masonry contractor Syosset NY ensures that brickwork, stonework, and other masonry installations are completed with precision. These elements not only strengthen the structure but also add timeless architectural charm that complements Long Island homes.<br>\n<br>Concrete installations are another key component. From foundations to outdoor walkways, properly installed concrete provides durability and safety. Services such as driveway paving Nassau County help homeowners maintain both the functionality and curb appeal of their properties.&nbsp;<br></p>\n                </div>\n            </div>\n            <div class=\"col-md-12 col-lg-6\" mbr-if=\"card > 1\">\n                <div class=\"wrapper\">\n                    <h5 class=\"mbr-section-title mbr-fonts-style mb-4\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-5\"><b>Designing Outdoor Living Spaces That Extend The Home</b></h5>\n                    <p class=\"mbr-text mbr-fonts-style\" data-app-selector=\".mbr-text\" mbr-theme-style=\"display-7\">Functional living spaces do not stop at the front door. Outdoor areas often serve as extensions of the home itself, especially in suburban communities like Syosset where residents value outdoor relaxation and entertaining.<br>\n<br>Builders design patios, decks, and seating areas that connect seamlessly with interior spaces. A well-planned outdoor environment might include a dining area for summer gatherings, shaded lounging spaces, and durable surfaces that withstand changing weather conditions.<br>\n<br>An experienced patio and deck builder Syosset understands how to design outdoor structures that complement the home’s architecture while remaining structurally sound. These features allow homeowners to enjoy Long Island’s warm summer evenings and crisp autumn days without leaving their property.<br>\n<br>During the planning stage, builders may also collaborate with professionals such as a <a href=\"https://maps.app.goo.gl/Ax423NhVssAfJtHg9\" class=\"text-primary\"><b><u>landscape designer</u></b></a> to ensure the outdoor layout aligns with the surrounding environment. While construction teams focus on structural components, coordinated planning helps create a cohesive and visually balanced property.&nbsp;<br></p>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "vengTBgNZf",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {},
          "_anchor": "features01-10"
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "& when (@showBorder)": {
              "overflow": "hidden"
            },
            ".content-wrapper": {
              "position": "relative",
              "display": "flex",
              "flex-direction": "column",
              "justify-content": "center",
              "padding-bottom": "(@paddingBottom * 1rem)",
              "& when (@showBorder)": {
                "padding-left": "20px",
                "padding-right": "20px",
                "border-bottom": "1px solid @border",
                "@media (max-width: 425px)": {
                  "padding-left": "0",
                  "padding-right": "0"
                },
                ".border-wrap": {
                  "position": "absolute",
                  "height": "1000%",
                  "width": "1px",
                  "border-left": "1px solid @border",
                  "pointer-events": "none",
                  "@media (max-width: 425px)": {
                    "display": "none"
                  }
                },
                ".border_1": {
                  "left": "0"
                },
                ".border_2": {
                  "right": "0"
                }
              },
              ".card-wrapper": {
                "padding": "32px",
                "background-color": "@cardBg",
                "box-shadow": "inset 0 10px 8px 0 @cardShadow_1, inset 0 -5px 10px -4px @cardShadow_2, 0 10px 10px -5px @cardShadow_2",
                "overflow": "hidden",
                "@media (max-width: 992px)": {
                  "padding": "24px"
                },
                ".title-wrapper": {
                  "@media (max-width: 992px)": {
                    "margin-bottom": "20px"
                  },
                  ".mbr-section-title": {
                    "margin-bottom": "16px"
                  },
                  ".text-wrapper": {
                    ".mbr-text": {
                      "margin-bottom": "0",
                      "@media (max-width: 992px)": {
                        "width": "100%"
                      }
                    }
                  },
                  ".mbr-section-btn": {
                    "margin-top": "10px"
                  }
                },
                ".image-wrapper": {
                  "img": {
                    "height": "400px",
                    "width": "100%",
                    "object-fit": "cover",
                    "@media (max-width: 992px)": {
                      "height": "450px"
                    }
                  }
                }
              }
            },
            ".items-wrapper": {
              "margin": "0 -20px",
              ".card": {
                "padding": "0 20px"
              }
            },
            ".mbr-section-title": {
              "color": "#0f172a"
            },
            ".mbr-text, .text-wrapper": {
              "color": "#000000"
            }
          },
          "_name": "article02",
          "_sourceTheme": "launchm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"article02 launchm5\" group=\"Article\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <input type=\"color\" title=\"Shadow 1\" value=\"#ffffff\" name=\"cardShadow_1\">\n        <input type=\"color\" title=\"Shadow 2\" value=\"#cccccc\" name=\"cardShadow_2\">\n        <input type=\"color\" title=\"Container BG\" value=\"#fafafa\" name=\"cardBg\">\n        <header>Border</header>\n        <input type=\"checkbox\" title=\"Border\" name=\"showBorder\" checked>\n        <input type=\"color\" title=\"Color\" value=\"#e1e7ed\" name=\"border\" condition=\"showBorder\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/launchm5/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#f5f5f5\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/launchm5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#f5f5f5\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-12 col-lg-10\">\n                <div class=\"content-wrapper\">\n                    <div class=\"border-wrap border_1\"></div>\n                    <div class=\"border-wrap border_2\"></div>\n                    <div class=\"card-wrapper\">\n                        <div class=\"row items-wrapper\">\n                            <div class=\"col-12 col-lg-6 card\">\n                                <div class=\"title-wrapper\">\n                                    <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .mbr-section-btn\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\"><b>Planning Expansions And Home Additions</b></h2>\n                                    <div class=\"text-wrapper\">\n                                        <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .text-wrapper\">As families grow, their homes must grow with them. Expanding the existing structure can provide additional bedrooms, larger kitchens, or expanded living areas without requiring homeowners to relocate.<br>\n<br>An experienced <a href=\"https://maps.app.goo.gl/6NezeWWMJngRik7C7\" class=\"text-primary\"><b><u>home addition contractor Long Island</u></b></a> carefully evaluates the original structure before designing an expansion. The goal is to ensure the new addition blends seamlessly with the existing architecture while maintaining structural integrity.<br>\n<br>Home additions often involve complex planning, including foundation work, framing, electrical systems, and interior finishing. A skilled general contractor Nassau County coordinates these phases so the project progresses smoothly from concept to completion.<br>\n<br>When executed properly, an addition can dramatically increase both the functionality and the market value of a home.&nbsp;<br></p>\n                                    </div>\n                                    <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                                        <a class=\"btn btn-black\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                            Get Started\n                                        </a>\n                                    </div>\n                                </div>\n                            </div>\n                            <div class=\"col-12 col-lg-6 card\">\n                                <div class=\"image-wrapper\">\n                                    <img class=\"little-radius\" src=\"@PROJECT_PATH@/assets/images/21.webp\" alt>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "vengTByKXX",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {},
          "_anchor": "article02-11"
        },
        {
          "_name": "tabs01",
          "_sourceTheme": "standm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"tabs01 tabs standm5\" group=\"List\" plugins=\"mbr-tabs\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <header>Tabs</header>\n        <select title=\"Count\" name=\"bootstrapTabs\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\">3</option>\n            <option value=\"4\" selected>4</option>\n        </select>\n        <input type=\"color\" title=\"Color\" value=\"#ffffff\" name=\"tabs\" selected>\n        <input type=\"color\" title=\"BG\" value=\"#000000\" name=\"tabsBg\" selected>\n        <input type=\"color\" title=\"Active Color\" value=\"#ffffff\" name=\"activeColor\" selected>\n        <input type=\"color\" title=\"Active BG\" value=\"#e70000\" name=\"activeBg\" selected>\n        <header>Cards</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Date\" name=\"showDate\">\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <input type=\"color\" title=\"BG 1\" value=\"#ffffff\" name=\"cardBg_1\" selected>\n        <input type=\"color\" title=\"BG 2\" value=\"#f7f7f7\" name=\"cardBg_2\" selected>\n        <input type=\"color\" title=\"Shadow\" value=\"#6c7179\" name=\"shadow\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/standm5/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#f7f7f7\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/standm5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-12 col-lg-10\">\n                <div class=\"content-wrapper\">\n                    <div class=\"row\">\n                        <div class=\"col-12\">\n                            <div class=\"tabs-wrapper\">\n                                <ul class=\"nav nav-tabs\" role=\"tablist\">\n                                    <li mbr-buttons mbr-theme-style=\"display-4\" class=\"nav-item first mbr-fonts-style\" data-toolbar=\"-mbrBtnAdd,-mbrBtnMove,-mbrLink,-mbrBtnRemove,-iconFont\"><a class=\"nav-link show mbr-fonts-style little-radius active\" data-app-placeholder=\"Type Text\" role=\"tab\" data-toggle=\"tab\" data-bs-toggle=\"tab\" href=\"#tabs01-5_tab0\" aria-selected=\"true\">\n                                            310 Harbor Rd, Cold Spring Harbor, NY 11724, USA\n                                        </a></li>\n                                    <li mbr-buttons mbr-theme-style=\"display-4\" class=\"nav-item\" mbr-if=\"bootstrapTabs > 1\" data-toolbar=\"-mbrBtnAdd,-mbrBtnMove,-mbrLink,-mbrBtnRemove,-iconFont\"><a class=\"nav-link mbr-fonts-style little-radius active\" data-app-placeholder=\"Type Text\" role=\"tab\" data-toggle=\"tab\" data-bs-toggle=\"tab\" href=\"#tabs01-5_tab1\" aria-selected=\"true\">\n                                            2500 6th St, East Meadow, NY 11554, USA\n                                        </a></li>\n                                    <li mbr-buttons mbr-theme-style=\"display-4\" class=\"nav-item\" mbr-if=\"bootstrapTabs > 2\" data-toolbar=\"-mbrBtnAdd,-mbrBtnMove,-mbrLink,-mbrBtnRemove,-iconFont\"><a class=\"nav-link mbr-fonts-style little-radius active\" data-app-placeholder=\"Type Text\" role=\"tab\" data-toggle=\"tab\" data-bs-toggle=\"tab\" href=\"#tabs01-5_tab2\" aria-selected=\"true\">\n                                            1135 Walt Whitman Rd, Melville, NY 11747, USA\n                                        </a></li>\n                                    <li mbr-buttons mbr-theme-style=\"display-4\" class=\"nav-item\" mbr-if=\"bootstrapTabs > 3\" data-toolbar=\"-mbrBtnAdd,-mbrBtnMove,-mbrLink,-mbrBtnRemove,-iconFont\"><a class=\"nav-link mbr-fonts-style little-radius active\" data-app-placeholder=\"Type Text\" role=\"tab\" data-toggle=\"tab\" data-bs-toggle=\"tab\" href=\"#tabs01-5_tab3\" aria-selected=\"true\">\n                                            8 Woodhollow Ln, Huntington, NY 11743, USA\n                                        </a></li>\n                                </ul>\n                            </div>\n                            <div class=\"tab-content\">\n                                <div id=\"tab1\" class=\"tab-pane in active\" role=\"tabpanel\">\n                                    <div class=\"card-wrapper large-radius\">\n                                        <div class=\"card-box card-wrap\">\n                                            <h4 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".item-title, .tabs-wrapper, .mbr-section-btn\" mbr-if=\"showTitle\"></h4>\n                                            <p class=\"item-date mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".item-date\" mbr-if=\"showDate\">\n                                                March 12, 2030\n                                            </p>\n                                            <p class=\"item-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".item-text\" mbr-if=\"showText\"></p>\n                                            <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove,-iconFont\">\n                                                <a class=\"btn btn-black\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                                    See More\n                                                </a>\n                                            </div>\n                                        </div>\n                                        <div class=\"image-wrap\">\n                                            <iframe src=\"https://www.google.com/maps/d/embed?mid=1P1gqkrjFVFunGV4oklU6nsBdTIJSqzA&ehbc=2E312F\" width=\"640\" height=\"480\"></iframe>\n                                        </div>\n                                    </div>\n                                </div>\n                                <div id=\"tab2\" class=\"tab-pane\" role=\"tabpanel\" mbr-if=\"bootstrapTabs > 1\">\n                                    <div class=\"card-wrapper large-radius\">\n                                        <div class=\"card-box card-wrap\">\n                                            <h4 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".item-title, .tabs-wrapper, .mbr-section-btn\" mbr-if=\"showTitle\"></h4>\n                                            <p class=\"item-date mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".item-date\" mbr-if=\"showDate\">\n                                                June 20, 2030\n                                            </p>\n                                            <p class=\"item-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".item-text\" mbr-if=\"showText\"></p>\n                                            <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove,-iconFont\">\n                                                <a class=\"btn btn-black\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                                    See More\n                                                </a>\n                                            </div>\n                                        </div>\n                                        <div class=\"image-wrap\">\n                                            <iframe src=\"https://www.google.com/maps/d/embed?mid=1voJ75HQHMONUPVPGUWGny8ruYljLVyM&ehbc=2E312F\" width=\"640\" height=\"480\"></iframe>\n                                        </div>\n                                    </div>\n                                </div>\n                                <div id=\"tab3\" class=\"tab-pane\" role=\"tabpanel\" mbr-if=\"bootstrapTabs > 2\">\n                                    <div class=\"card-wrapper large-radius\">\n                                        <div class=\"card-box card-wrap\">\n                                            <h4 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".item-title, .tabs-wrapper, .mbr-section-btn\" mbr-if=\"showTitle\"></h4>\n                                            <p class=\"item-date mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".item-date\" mbr-if=\"showDate\">\n                                                September 5, 2030\n                                            </p>\n                                            <p class=\"item-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".item-text\" mbr-if=\"showText\"></p>\n                                            <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove,-iconFont\">\n                                                <a class=\"btn btn-black\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                                    See More\n                                                </a>\n                                            </div>\n                                        </div>\n                                        <div class=\"image-wrap\">\n                                            <iframe src=\"https://www.google.com/maps/d/embed?mid=152Mfe7T5dcVkRr3SypEGl2Tr7zda5dg&ehbc=2E312F\" width=\"640\" height=\"480\"></iframe>\n                                        </div>\n                                    </div>\n                                </div>\n                                <div id=\"tab4\" class=\"tab-pane\" role=\"tabpanel\" mbr-if=\"bootstrapTabs > 3\">\n                                    <div class=\"card-wrapper large-radius\">\n                                        <div class=\"card-box card-wrap\">\n                                            <h4 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".item-title, .tabs-wrapper, .mbr-section-btn\" mbr-if=\"showTitle\">500 Searingtown Rd, Roslyn, NY 11576, USA</h4>\n                                            <p class=\"item-date mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".item-date\" mbr-if=\"showDate\">\n                                                December 3, 2030\n                                            </p>\n                                            <p class=\"item-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".item-text\" mbr-if=\"showText\"><iframe src=\"https://www.google.com/maps/d/embed?mid=1C4jHvOnIbmM-uxI4MNV1XYXa_nqaqaw&ehbc=2E312F\" width=\"640\" height=\"480\"></iframe></p>\n                                            <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove,-iconFont\">\n                                                <a class=\"btn btn-black\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                                    See More\n                                                </a>\n                                            </div>\n                                        </div>\n                                        <div class=\"image-wrap\">\n                                            <iframe src=\"https://www.google.com/maps/d/embed?mid=1w19kpBDC2pgpWbHuXjA1dCHc1QwNZI4&ehbc=2E312F\" width=\"640\" height=\"480\"></iframe>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".tabs-wrapper": {
              "margin-bottom": "40px",
              ".nav.nav-tabs": {
                "border": "none",
                "padding": "0",
                "border-radius": "0 !important",
                "background-color": "transparent",
                "display": "inline-flex",
                "flex-wrap": "wrap",
                "gap": "12px",
                ".nav-item": {
                  "padding": "0",
                  "border": "none",
                  "display": "block",
                  "margin": "0",
                  ".nav-link": {
                    "position": "relative",
                    "display": "flex",
                    "align-items": "center",
                    "justify-content": "center",
                    "color": "@tabs",
                    "padding": "17px 24px",
                    "background-color": "@tabsBg",
                    "border": "none",
                    "transition": "background-color 1s ease-in-out",
                    "z-index": "1",
                    "overflow": "hidden",
                    "&::after": {
                      "content": "''",
                      "width": "12px",
                      "height": "12px",
                      "border-radius": "100%",
                      "transition": "all .8s ease",
                      "z-index": "-1",
                      "transform": "scale(1)",
                      "background-color": "@activeBg",
                      "margin-left": "16px",
                      "pointer-events": "none"
                    },
                    "&::before": {
                      "content": "''",
                      "position": "absolute",
                      "right": "24px",
                      "width": "12px",
                      "height": "12px",
                      "border-radius": "100%",
                      "transition": "all .8s ease",
                      "z-index": "1",
                      "opacity": "0",
                      "pointer-events": "none",
                      "background-color": "@activeColor"
                    },
                    "&:hover": {
                      "&::after": {
                        "transform": "scale(1.3)"
                      }
                    }
                  },
                  ".nav-link.active": {
                    "color": "@activeColor",
                    "background-color": "@activeBg",
                    "&::after": {
                      "transform": "scale(50)"
                    },
                    "&::before": {
                      "opacity": "1"
                    }
                  }
                }
              }
            },
            ".tab-content": {
              ".tab-pane": {
                ".card-wrapper": {
                  "display": "grid",
                  "grid-template-columns": "1fr 1fr",
                  "gap": "8px",
                  "background-color": "@cardBg_1",
                  "padding": "8px",
                  "box-shadow": "0 10px 25px -20px @shadow",
                  "@media (max-width: 992px)": {
                    "grid-template-columns": "1fr"
                  },
                  ".card-box": {
                    "padding": "24px",
                    "background-color": "@cardBg_2",
                    "@media (max-width: 992px)": {
                      "padding": "20px"
                    },
                    ".item-title": {
                      "margin-bottom": "12px"
                    },
                    ".item-date": {
                      "margin-bottom": "20px"
                    },
                    ".item-text": {
                      "margin-bottom": "0"
                    },
                    ".mbr-section-btn": {
                      "margin-top": "12px",
                      ".btn": {
                        "margin-bottom": "0"
                      }
                    }
                  },
                  ".image-wrap": {
                    "position": "relative",
                    "min-height": "420px",
                    "height": "100%",
                    "@media (max-width: 992px)": {
                      "height": "300px",
                      "min-height": "auto"
                    },
                    "img": {
                      "position": "absolute",
                      "top": "0",
                      "left": "0",
                      "width": "100%",
                      "height": "100%",
                      "object-fit": "cover"
                    }
                  }
                }
              }
            },
            ".item-title": {
              "color": "#000000"
            },
            ".item-date": {
              "color": "#454545"
            },
            ".item-text": {
              "color": "#6c7179"
            }
          },
          "_PHPplaceholders": [],
          "_JSplaceholders": [],
          "_cid": "vengTBS3DM",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {},
          "_anchor": "tabs01-12"
        },
        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".mbr-section-subtitle": {
              "background": "white",
              "color": "#ffffff",
              "width": "fit-content",
              "border-radius": "2rem",
              "padding": "5px 1rem",
              "text-align": "left"
            },
            ".subtitle-wrap": {
              "display": "inline-flex",
              "border-radius": "2rem",
              "padding": "0.5rem",
              "padding-bottom": "0",
              "background": "@primaryColor",
              "flex-direction": "row",
              "width": "fit-content",
              "align-items": "center",
              "margin-bottom": "2rem",
              ".mbr-iconfont": {
                "padding": "0 15px",
                "padding-bottom": "8px",
                "margin": "0",
                "color": "@secondaryColor",
                "font-size": "1.5rem"
              }
            },
            ".mbr-section-title": {
              "color": "#04492e"
            },
            ".mbr-text, .mbr-section-btn": {
              "color": "#000000"
            },
            ".mbr-section-subtitle, .align-wrapper": {
              "color": "#04492e",
              "text-align": "center"
            }
          },
          "_name": "article01",
          "_sourceTheme": "discretem5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"article1\" group=\"Article\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"7\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"7\" condition=\"fullScreen == false\">\n\n        <input type=\"range\" inline name=\"textWidth\" title=\"Width\" min=\"4\" max=\"12\" value=\"9\" step=\"1\">\n        <select title=\"Align\" name=\"contentAlign\">\n            <option value selected>Left</option>\n            <option value=\"justify-content-center\">Center</option>\n            <option value=\"justify-content-end\">Right</option>\n        </select>\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\">\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#fafaf9\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#fafafa\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.1\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div class mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row  align-left {{contentAlign}}\">\n            <div class=\"col-12 col-lg-{{textWidth}}\">\n                <div class=\"align-wrapper\" mbr-if=\"showSubitle\">\n                    <div class=\"subtitle-wrap\">\n                        <span mbr-icon class=\"mbr-iconfont mobi-mbri-idea mobi-mbri\" style=\"color: rgb(240, 48, 74); fill: rgb(240, 48, 74);\"></span>\n                        <h2 class=\"mbr-section-subtitle mbr-fonts-style\" data-app-selector=\".mbr-section-subtitle, .align-wrapper\" mbr-theme-style=\"display-5\" mbr-if=\"showSubitle\"><b>Renovation And Remodeling For Long-Term Functionality</b></h2>\n                    </div>\n                </div>\n                <h1 class=\"mbr-section-title mbr-fonts-style mb-3\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\"><b>How to Manage <br>Your Business</b></h1>\n\n                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\">Not every homeowner needs a completely new house. In many cases, strategic renovations can transform an outdated structure into a modern and highly functional living environment.<br>\n<br>Projects such as concrete home remodeling Long Island often involve updating foundations, improving structural components, and redesigning interior spaces to better serve modern lifestyles. Kitchens, bathrooms, and basements are particularly popular renovation areas because they significantly impact daily living.<br>\n<br>Builders also evaluate opportunities to improve energy efficiency, enhance natural lighting, and upgrade building materials during remodeling projects. These improvements ensure the home continues to perform well for decades.<br>\n<br>With the guidance of a reliable builder like ORA Construction, homeowners gain access to expert planning, high-quality craftsmanship, and careful project management that keeps renovations organized and stress-free.&nbsp;<br></p>\n                <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn mt-3\" mbr-if=\"showButtons\"><a class=\"btn btn-secondary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">Create\n                        Website</a></div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "vengTCuHE8",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {},
          "_anchor": "article01-13"
        },
        {
          "_name": "list03",
          "_sourceTheme": "promotionm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"list03 promotionm5\" group=\"List\" plugins=\"mbr-switch-arrow, mobirise-icons2\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Label\" name=\"showLabel\">\n        <input type=\"checkbox\" title=\"Icon\" name=\"showIcon\" checked condition=\"showLabel\">\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <header>List</header>\n        <select title=\"Amount\" name=\"cardAmount\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\">3</option>\n            <option value=\"4\">4</option>\n            <option value=\"5\" selected>5</option>\n            <option value=\"6\">6</option>\n        </select>\n        <header>Cards</header>\n        <input type=\"checkbox\" title=\"Number\" name=\"showNumber\" checked>\n        <input type=\"color\" title=\"Icon Color\" value=\"#ffffff\" name=\"iconColor\" selected>\n        <input type=\"color\" title=\"Icon BG\" value=\"#f3350c\" name=\"iconBg\" selected>\n        <input type=\"color\" title=\"Active Color\" value=\"#1f1f1f\" name=\"activeColor\" selected>\n        <input type=\"color\" title=\"Active BG\" value=\"#c6c6c6\" name=\"activeBg\" selected>\n        <input type=\"color\" title=\"Border Color\" value=\"#c6c6c6\" name=\"border\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/promotionm5/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#f1f1f1\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/promotionm5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-12 col-lg-10\">\n                <div class=\"content-wrapper\">\n                    <div class=\"row content-wrap\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n                        <div class=\"col-12 col-lg-3 card\">\n                            <div class=\"label-wrapper\" mbr-if=\"showLabel\">\n                                <div class=\"label-wrap\">\n                                    <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n                                        <span mbr-icon class=\"card-icon mbr-iconfont mobi-mbri-shopping-basket mobi-mbri\" data-app-selector=\".card-icon\" style=\"color: rgb(31, 31, 31); fill: rgb(31, 31, 31);\"></span>\n                                    </div>\n                                    <p class=\"mbr-label mbr-fonts-style\" data-app-selector=\".mbr-label, .label-wrapper\" mbr-theme-style=\"display-7\">\n                                        Radiance\n                                    </p>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"col-12 col-lg-7 card\">\n                            <div class=\"title-wrapper\">\n                                <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .title-wrapper, .main-btn\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\">\n                                    FAQs</h2>\n                            </div>\n                            <div id=\"bootstrap-accordion\" class=\"panel-group accordionStyles accordion\" role=\"tablist\" aria-multiselectable=\"true\">\n                                <div class=\"card little-radius\">\n                                    <div class=\"card-header\" role=\"tab\" id=\"headingOne\">\n                                        <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse1\" aria-expanded=\"false\" aria-controls=\"collapse1\">\n                                            <div class=\"title-wrap\">\n                                                <h4 class=\"panel-number mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-number\" mbr-if=\"showNumber\">\n                                                    01\n                                                </h4>\n                                                <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">Why should homeowners hire professionals for concrete installation?</h4>\n                                            </div>\n                                            <div class=\"icon-wrapper card-wrap little-radius\">\n                                                <span class=\"sign mobi-mbri mobi-mbri-plus mbr-iconfont\"></span>\n                                            </div>\n                                        </a>\n                                    </div>\n                                    <div id=\"collapse1\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingOne\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                        <div class=\"panel-body\">\n                                            <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">Professional contractors ensure proper preparation, reinforcement, and curing, which prevents structural problems and significantly increases the lifespan of the concrete surface.&nbsp;<br></p>\n                                        </div>\n                                    </div>\n                                </div>\n                                <div class=\"card little-radius\" mbr-if=\"cardAmount > 1\">\n                                    <div class=\"card-header\" role=\"tab\" id=\"headingTwo\">\n                                        <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse2\" aria-expanded=\"false\" aria-controls=\"collapse2\">\n                                            <div class=\"title-wrap\">\n                                                <h4 class=\"panel-number mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-number\" mbr-if=\"showNumber\">\n                                                    02\n                                                </h4>\n                                                <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">How long does professionally installed concrete last?</h4>\n                                            </div>\n                                            <div class=\"icon-wrapper card-wrap little-radius\">\n                                                <span class=\"sign mobi-mbri mobi-mbri-plus mbr-iconfont\"></span>\n                                            </div>\n                                        </a>\n                                    </div>\n                                    <div id=\"collapse2\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingTwo\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                        <div class=\"panel-body\">\n                                            <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">When installed correctly, concrete surfaces can last between 30 and 50 years while requiring only minimal maintenance.&nbsp;<br></p>\n                                        </div>\n                                    </div>\n                                </div>\n                                <div class=\"card little-radius\" mbr-if=\"cardAmount > 2\">\n                                    <div class=\"card-header\" role=\"tab\" id=\"headingThree\">\n                                        <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse3\" aria-expanded=\"false\" aria-controls=\"collapse3\">\n                                            <div class=\"title-wrap\">\n                                                <h4 class=\"panel-number mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-number\" mbr-if=\"showNumber\">\n                                                    03\n                                                </h4>\n                                                <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">What types of projects require professional concrete installation?</h4>\n                                            </div>\n                                            <div class=\"icon-wrapper card-wrap little-radius\">\n                                                <span class=\"sign mobi-mbri mobi-mbri-plus mbr-iconfont\"></span>\n                                            </div>\n                                        </a>\n                                    </div>\n                                    <div id=\"collapse3\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingThree\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                        <div class=\"panel-body\">\n                                            <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">Common projects include driveways, patios, sidewalks, structural foundations, and outdoor living spaces that require strong, durable materials.&nbsp;<br></p>\n                                        </div>\n                                    </div>\n                                </div>\n                                <div class=\"card little-radius\" mbr-if=\"cardAmount > 3\">\n                                    <div class=\"card-header\" role=\"tab\" id=\"headingFour\">\n                                        <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse4\" aria-expanded=\"false\" aria-controls=\"collapse4\">\n                                            <div class=\"title-wrap\">\n                                                <h4 class=\"panel-number mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-number\" mbr-if=\"showNumber\">\n                                                    04\n                                                </h4>\n                                                <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">Can concrete installations increase property value?</h4>\n                                            </div>\n                                            <div class=\"icon-wrapper card-wrap little-radius\">\n                                                <span class=\"sign mobi-mbri mobi-mbri-plus mbr-iconfont\"></span>\n                                            </div>\n                                        </a>\n                                    </div>\n                                    <div id=\"collapse4\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingFour\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                        <div class=\"panel-body\">\n                                            <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">Yes. Well-designed driveways, patios, and walkways enhance both curb appeal and functionality, making homes more attractive to potential buyers.&nbsp;<br></p>\n                                        </div>\n                                    </div>\n                                </div>\n                                <div class=\"card little-radius\" mbr-if=\"cardAmount > 4\">\n                                    <div class=\"card-header\" role=\"tab\" id=\"headingFive\">\n                                        <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse5\" aria-expanded=\"false\" aria-controls=\"collapse5\">\n                                            <div class=\"title-wrap\">\n                                                <h4 class=\"panel-number mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-number\" mbr-if=\"showNumber\">\n                                                    05\n                                                </h4>\n                                                <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">How do I choose the right contractor for a concrete project?</h4>\n                                            </div>\n                                            <div class=\"icon-wrapper card-wrap little-radius\">\n                                                <span class=\"sign mobi-mbri mobi-mbri-plus mbr-iconfont\"></span>\n                                            </div>\n                                        </a>\n                                    </div>\n                                    <div id=\"collapse5\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingFive\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                        <div class=\"panel-body\">\n                                            <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">Look for a licensed and insured contractor with experience in construction, masonry, and residential building projects, as well as a reputation for delivering reliable results.&nbsp;<br></p>\n                                        </div>\n                                    </div>\n                                </div>\n                                <div class=\"card little-radius\" mbr-if=\"cardAmount > 5\">\n                                    <div class=\"card-header\" role=\"tab\" id=\"headingSix\">\n                                        <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse6\" aria-expanded=\"false\" aria-controls=\"collapse6\">\n                                            <div class=\"title-wrap\">\n                                                <h4 class=\"panel-number mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-number\" mbr-if=\"showNumber\">\n                                                    06\n                                                </h4>\n                                                <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-title-edit\">\n                                                    How do you support models’ careers long-term?\n                                                </h4>\n                                            </div>\n                                            <div class=\"icon-wrapper card-wrap little-radius\">\n                                                <span class=\"sign mobi-mbri mobi-mbri-plus mbr-iconfont\"></span>\n                                            </div>\n                                        </a>\n                                    </div>\n                                    <div id=\"collapse6\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingSix\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                        <div class=\"panel-body\">\n                                            <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-text\">\n                                                We offer mentoring, career planning, and access to industry connections,\n                                                helping models grow and maintain a successful career over time.\n                                            </p>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".content-wrap": {
              "margin": "0 -50px",
              ".card": {
                "padding": "0 50px"
              },
              ".label-wrapper": {
                "margin-bottom": "20px",
                ".label-wrap": {
                  "display": "inline-flex",
                  "flex-wrap": "wrap",
                  "align-items": "center",
                  "gap": "8px",
                  ".iconfont-wrapper": {
                    "display": "flex",
                    ".mbr-iconfont": {
                      "display": "inline-flex",
                      "font-size": "20px"
                    }
                  },
                  ".mbr-label": {
                    "margin-bottom": "0"
                  }
                }
              },
              ".title-wrapper": {
                ".mbr-section-title": {
                  "margin-bottom": "50px"
                }
              }
            },
            ".panel-group": {
              ".card": {
                "position": "relative",
                "background-color": "transparent",
                "border-bottom": "1px solid @border",
                "border-radius": "0 !important",
                "padding": "30px 0",
                "@media (max-width: 992px)": {
                  "padding": "20px 0"
                },
                "&:first-child": {
                  "border-top": "1px solid @border"
                },
                ".card-header": {
                  "background-color": "transparent",
                  "border": "none",
                  "border-radius": "0",
                  "padding": "0",
                  ".panel-title": {
                    "display": "flex",
                    "justify-content": "space-between",
                    "align-items": "center",
                    "width": "100%",
                    "padding": "0",
                    ".title-wrap": {
                      "display": "flex",
                      "align-items": "center",
                      "gap": "20px",
                      "@media (max-width: 992px)": {
                        "display": "block"
                      },
                      ".panel-number": {
                        "margin-bottom": "0",
                        "white-space": "nowrap",
                        "@media (max-width: 992px)": {
                          "margin-bottom": "20px",
                          "width": "0"
                        }
                      },
                      ".panel-title-edit": {
                        "margin-bottom": "0"
                      }
                    },
                    ".icon-wrapper": {
                      "width": "24px",
                      "height": "24px",
                      "min-width": "24px",
                      "display": "inline-flex",
                      "align-items": "center",
                      "justify-content": "center",
                      "margin-left": "24px",
                      "transition": "all 0.3s ease-in-out",
                      "background-color": "@iconBg",
                      ".mbr-iconfont": {
                        "font-size": "10px",
                        "transition": "all 0.3s ease-in-out",
                        "color": "@iconColor"
                      }
                    },
                    "&:not(.collapsed)": {
                      ".icon-wrapper": {
                        "background-color": "@activeBg",
                        ".mbr-iconfont": {
                          "transform": "rotate(-45deg)",
                          "color": "@activeColor"
                        }
                      }
                    }
                  }
                },
                ".panel-collapse": {
                  ".panel-body": {
                    "padding": "20px 44px 0 44px",
                    "@media (max-width: 992px)": {
                      "padding": "20px 0 0 0"
                    },
                    ".panel-text": {
                      "margin-bottom": "0"
                    }
                  }
                }
              }
            },
            ".mbr-label": {
              "color": "#1f1f1f"
            },
            ".mbr-section-title": {
              "color": "#1f1f1f"
            },
            ".panel-number": {
              "color": "#1f1f1f"
            },
            ".panel-title-edit": {
              "color": "#1f1f1f"
            },
            ".item-text": {
              "color": "#5a5a5a"
            }
          },
