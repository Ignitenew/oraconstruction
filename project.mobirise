        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "img": {
              "border-radius": "2rem"
            },
            ".mbr-section-subtitle": {
              "background": "white",
              "color": "#ffffff",
              "width": "fit-content",
              "border-radius": "2rem",
              "padding": "5px 1rem",
              "text-align": "left"
            },
            ".subtitle-wrap": {
              "display": "inline-flex",
              "border-radius": "2rem",
              "padding": "0.5rem",
              "padding-bottom": "0",
              "background": "@primaryColor",
              "flex-direction": "row",
              "width": "fit-content",
              "align-items": "center",
              "margin-bottom": "2rem",
              ".mbr-iconfont": {
                "padding": "0 15px",
                "padding-bottom": "8px",
                "margin": "0",
                "color": "@secondaryColor",
                "font-size": "1.5rem"
              }
            },
            ".mbr-section-title": {
              "color": "#ffffff"
            },
            ".mbr-text, .mbr-section-btn": {
              "color": "#ffffff"
            },
            ".mbr-section-subtitle, .align-wrapper": {
              "color": "#04492e"
            }
          },
          "_name": "header03",
          "_sourceTheme": "discretem5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"header3\" group=\"Header\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"10\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"7\" condition=\"fullScreen == false\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubitle\">\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@THEME_PATH@/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#04492e\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@THEME_PATH@/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#fafafa\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.1\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div class mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row  align-left {{contentAlign}}\">\n            <div class=\"col-12 m-auto col-lg-7 pb-5\">\n                <div class=\"align-wrapper\" mbr-if=\"showSubitle\">\n                    <div class=\"subtitle-wrap\">\n                        <span mbr-icon class=\"mbr-iconfont mobi-mbri-rocket mobi-mbri\"></span>\n                        <h2 class=\"mbr-section-subtitle mbr-fonts-style\" data-app-selector=\".mbr-section-subtitle, .align-wrapper\" mbr-theme-style=\"display-4\" mbr-if=\"showSubitle\"><b>Get Started</b></h2>\n                    </div>\n                </div>\n                <h1 class=\"mbr-section-title mbr-fonts-style mb-3\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-1\" mbr-if=\"showTitle\"><b>How Construction Improves The Functionality Of Homes In Syosset, NY</b></h1>\n\n                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\">Learn how construction improves the functionality of homes in Syosset, NY. Discover how renovations, home additions, basement remodeling, and new home construction enhance comfort, efficiency, and property value.</p>\n                <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn mt-3\" mbr-if=\"showButtons\"><a class=\"btn btn-secondary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">About Us</a>\n                    <a class=\"btn btn-white\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">Read More</a></div>\n            </div>\n            <div class=\"col-lg-5\">\n                <img src=\"@PROJECT_PATH@/assets/images/17.webp\" alt>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "tBnM9yQwvx",
          "_anchor": "header03-2",
          "_PHPplaceholders": [],
          "_JSplaceholders": [],
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "list02",
          "_sourceTheme": "sharpm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"list02 sharpm5\" group=\"List\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\">\n        <header>Cards</header>\n        <input type=\"checkbox\" title=\"Number\" name=\"showNumber\" checked>\n        <input type=\"color\" title=\"Border Color\" value=\"#fefff5\" name=\"number\" condition=\"showNumber\" selected>\n        <input type=\"checkbox\" title=\"Title\" name=\"showCardTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\">\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showCardButtons\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/sharpm5/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#191919\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/sharpm5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#191919\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12 col-lg-5 card\">\n                <div class=\"title-wrapper\">\n                    <div class=\"title-wrap\" mbr-if=\"showTitle || showSubtitle\">\n                        <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-4\" mbr-if=\"showTitle\">Ora Construction - Home Remodeling, Masonry &amp; Landscape Design</h2>\n                        <h3 class=\"mbr-section-subtitle mbr-fonts-style\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-2\" mbr-if=\"showSubtitle\">\n                            Business Success\n                        </h3>\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-5 card\">\n                <div class=\"items-wrapper\">\n                    <div class=\"item features-without-image\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"number-wrapper\">\n                                <p class=\"item-number mbr-fonts-style\" mbr-if=\"showNumber\" mbr-theme-style=\"display-7\" data-app-selector=\".item-number, .number-wrapper\">\n                                    1\n                                </p>\n                            </div>\n                            <h4 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".item-title\" mbr-if=\"showCardTitle\"><a href=\"index.html#header02-m\" class=\"text-primary\">ORA Construction: Building Strong Foundations For Every Project</a></h4>\n                            <p class=\"item-text mbr-fonts-style\" mbr-if=\"showText\" mbr-theme-style=\"display-4\" data-app-selector=\".item-text\">\n                                We begin by gaining a deep understanding of your business, industry, and unique\n                                challenges.\n                            </p>\n                            <div class=\"mbr-section-btn item-btn\" mbr-if=\"showCardButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\" mbr-buttons mbr-theme-style=\"display-4\">\n                                <a href class=\"btn btn-primary\" data-app-placeholder=\"Type Text\">\n                                    Learn More\n                                </a>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"item features-without-image\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"number-wrapper\">\n                                <p class=\"item-number mbr-fonts-style\" mbr-if=\"showNumber\" mbr-theme-style=\"display-7\" data-app-selector=\".item-number, .number-wrapper\">\n                                    2\n                                </p>\n                            </div>\n                            <h4 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".item-title\" mbr-if=\"showCardTitle\"><a href=\"index.html#article03-l\" class=\"text-primary\">Renovations That Make Everyday Living Easier</a></h4>\n                            <p class=\"item-text mbr-fonts-style\" mbr-if=\"showText\" mbr-theme-style=\"display-4\" data-app-selector=\".item-text\">\n                                Based on our analysis, we develop a tailored roadmap designed to achieve your goals.\n                            </p>\n                            <div class=\"mbr-section-btn item-btn\" mbr-if=\"showCardButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\" mbr-buttons mbr-theme-style=\"display-4\">\n                                <a href class=\"btn btn-primary\" data-app-placeholder=\"Type Text\">\n                                    Learn More\n                                </a>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"item features-without-image\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"number-wrapper\">\n                                <p class=\"item-number mbr-fonts-style\" mbr-if=\"showNumber\" mbr-theme-style=\"display-7\" data-app-selector=\".item-number, .number-wrapper\">\n                                    3\n                                </p>\n                            </div>\n                            <h4 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".item-title\" mbr-if=\"showCardTitle\"><a href=\"index.html#features01-p\" class=\"text-primary\">Expanding Homes To Support Growing Families</a></h4>\n                            <p class=\"item-text mbr-fonts-style\" mbr-if=\"showText\" mbr-theme-style=\"display-4\" data-app-selector=\".item-text\">\n                                Strategy is only as good as its execution. We work alongside your team to implement\n                                solutions, track performance.\n                            </p>\n                            <div class=\"mbr-section-btn item-btn\" mbr-if=\"showCardButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\" mbr-buttons mbr-theme-style=\"display-4\">\n                                <a href class=\"btn btn-primary\" data-app-placeholder=\"Type Text\">\n                                    Learn More\n                                </a>\n                            </div>\n                        </div>\n                    </div><div class=\"item features-without-image\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"number-wrapper\">\n                                <p class=\"item-number mbr-fonts-style\" mbr-if=\"showNumber\" mbr-theme-style=\"display-7\" data-app-selector=\".item-number, .number-wrapper\">\n                                    4\n                                </p>\n                            </div>\n                            <h4 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".item-title\" mbr-if=\"showCardTitle\"><a href=\"index.html#features01-p\" class=\"text-primary\">Structural Improvements That Strengthen And Protect Homes</a></h4>\n                            <p class=\"item-text mbr-fonts-style\" mbr-if=\"showText\" mbr-theme-style=\"display-4\" data-app-selector=\".item-text\">\n                                Strategy is only as good as its execution. We work alongside your team to implement\n                                solutions, track performance.\n                            </p>\n                            <div class=\"mbr-section-btn item-btn\" mbr-if=\"showCardButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\" mbr-buttons mbr-theme-style=\"display-4\">\n                                <a href class=\"btn btn-primary\" data-app-placeholder=\"Type Text\">\n                                    Learn More\n                                </a>\n                            </div>\n                        </div>\n                    </div><div class=\"item features-without-image\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"number-wrapper\">\n                                <p class=\"item-number mbr-fonts-style\" mbr-if=\"showNumber\" mbr-theme-style=\"display-7\" data-app-selector=\".item-number, .number-wrapper\">\n                                    5\n                                </p>\n                            </div>\n                            <h4 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".item-title\" mbr-if=\"showCardTitle\"><a href=\"index.html#article02-2\" class=\"text-primary\">Turning Basements Into Functional Living Areas</a></h4>\n                            <p class=\"item-text mbr-fonts-style\" mbr-if=\"showText\" mbr-theme-style=\"display-4\" data-app-selector=\".item-text\">\n                                Strategy is only as good as its execution. We work alongside your team to implement\n                                solutions, track performance.\n                            </p>\n                            <div class=\"mbr-section-btn item-btn\" mbr-if=\"showCardButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\" mbr-buttons mbr-theme-style=\"display-4\">\n                                <a href class=\"btn btn-primary\" data-app-placeholder=\"Type Text\">\n                                    Learn More\n                                </a>\n                            </div>\n                        </div>\n                    </div><div class=\"item features-without-image\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"number-wrapper\">\n                                <p class=\"item-number mbr-fonts-style\" mbr-if=\"showNumber\" mbr-theme-style=\"display-7\" data-app-selector=\".item-number, .number-wrapper\">\n                                    6\n                                </p>\n                            </div>\n                            <h4 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".item-title\" mbr-if=\"showCardTitle\"><a href=\"index.html#article01-4\" class=\"text-primary\">Building New Homes Designed For Modern Living</a></h4>\n                            <p class=\"item-text mbr-fonts-style\" mbr-if=\"showText\" mbr-theme-style=\"display-4\" data-app-selector=\".item-text\">\n                                Strategy is only as good as its execution. We work alongside your team to implement\n                                solutions, track performance.\n                            </p>\n                            <div class=\"mbr-section-btn item-btn\" mbr-if=\"showCardButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\" mbr-buttons mbr-theme-style=\"display-4\">\n                                <a href class=\"btn btn-primary\" data-app-placeholder=\"Type Text\">\n                                    Learn More\n                                </a>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".row": {
              "margin": "0 -15px",
              ".card": {
                "padding": "0 15px"
              }
            },
            ".title-wrapper": {
              "position": "sticky",
              "top": "40px",
              "@media (max-width: 992px)": {
                "margin-bottom": "40px",
                "position": "static"
              },
              ".title-wrap": {
                ".mbr-section-title": {
                  "margin-bottom": "0"
                },
                ".mbr-section-subtitle": {
                  "margin-bottom": "0"
                }
              }
            },
            ".items-wrapper": {
              ".item": {
                "margin-bottom": "50px",
                "@media (max-width: 992px)": {
                  "margin-bottom": "40px"
                },
                "&:last-child": {
                  "margin-bottom": "0"
                },
                ".item-wrapper": {
                  ".item-number": {
                    "width": "50px",
                    "height": "50px",
                    "min-width": "50px",
                    "display": "inline-flex",
                    "justify-content": "center",
                    "align-items": "center",
                    "border-radius": "100%",
                    "border": "1px solid @number",
                    "margin-bottom": "30px",
                    "@media (max-width: 992px)": {
                      "margin-bottom": "20px"
                    }
                  }
                },
                ".item-title": {
                  "margin-bottom": "30px",
                  "@media (max-width: 992px)": {
                    "margin-bottom": "20px"
                  }
                },
                ".item-text": {
                  "margin-bottom": "20px"
                },
                ".mbr-section-btn": {
                  ".btn": {
                    "margin-bottom": "0"
                  }
                }
              }
            },
            ".mbr-section-title": {
              "color": "#fefff5"
            },
            ".mbr-section-subtitle": {
              "color": "#a1a1a1"
            },
            ".item-number": {
              "color": "#fefff5"
            },
            ".item-title": {
              "color": "#fefff5"
            },
            ".item-text": {
              "color": "#fefff5"
            }
          },
