              }
            },
            ".mbr-text": {
              "color": "#fafaf9"
            },
            ".mbr-section-title": {
              "color": "#ffffff",
              "text-align": "center"
            },
            "p": {
              "opacity": "0.7"
            },
            ".wrapper": {
              "background": "@bgCard",
              "padding": "4rem",
              "border-radius": "2rem",
              "@media (max-width: 992px)": {
