        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value",
              "& when (@showGradientBg)": {
                "background-image": "linear-gradient(180deg, @gradientColor_1 0%, @bg-value 100%)"
              }
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".title-wrapper": {
              "margin-bottom": "50px",
              "@media (max-width: 992px)": {
                "margin-bottom": "40px"
              },
              ".mbr-label": {
                "margin-bottom": "30px"
              },
              ".mbr-section-title": {
                "margin-bottom": "0"
              },
              ".mbr-text": {
                "margin-top": "20px",
                "margin-bottom": "0"
              },
              ".mbr-section-btn": {
                "margin-top": "20px",
                "margin-bottom": "-9.6px"
              }
            },
            ".nav-wrapper": {
              "display": "flex",
              "justify-content": "center",
              "flex-wrap": "wrap",
              "gap": "30px 0",
              "margin-bottom": "50px",
              "@media (max-width: 992px)": {
                "margin-bottom": "40px"
              },
              ".nav-wrap": {
                "padding-left": "20px",
                "width": "25%",
                "@media (max-width: 1440px)": {
                  "padding-left": "0",
                  "width": "50%"
                },
                "@media (max-width: 768px)": {
                  "width": "100%"
                },
                "&:first-child": {
                  "padding-left": "0"
                },
                "&:nth-child(3n)": {
                  "@media (max-width: 1440px)": {
                    "padding-left": "0"
                  }
                },
                ".mbr-list-title": {
                  "margin-bottom": "20px",
                  "@media (max-width: 992px)": {
                    "margin-bottom": "16px"
                  }
                },
                ".list": {
                  "padding": "0",
                  "margin": "0",
                  "list-style-type": "none",
                  ".item-wrap": {
                    "margin-bottom": "16px",
                    "transition": "all 0.3s ease-in-out",
                    "@media (max-width: 992px)": {
                      "margin-bottom": "10px"
                    },
                    "&:hover, &:focus": {
                      "opacity": "0.7"
                    },
                    "&:last-child": {
                      "margin-bottom": "0"
                    }
                  }
                }
              }
            },
            ".border-wrap": {
              "margin-bottom": "50px",
              "width": "100%",
              "height": "1px",
              "opacity": ".4",
              "background-color": "@border",
              "@media (max-width: 992px)": {
                "margin-bottom": "40px"
              }
            },
            ".card": {
              "justify-content": "center"
            },
            ".mbr-copy": {
              "margin-bottom": "0",
              "opacity": ".7",
              "color": "#ffffff",
              "text-align": "center"
            },
            ".social-wrapper": {
              "@media (max-width: 992px)": {
                "margin-bottom": "40px",
                "text-align": "left"
              },
              ".social-wrap": {
                "display": "inline-flex",
                "justify-content": "flex-end",
                "flex-wrap": "wrap",
                "gap": "30px",
                "@media (max-width: 992px)": {
                  "justify-content": "flex-start"
                },
                ".soc-item": {
                  "display": "inline-flex",
                  "align-items": "center",
                  "justify-content": "center",
                  "width": "25px",
                  "height": "25px",
                  "transition": "all .3s ease",
                  "&:hover, &:hover": {
                    "opacity": ".7",
                    "a.mbr-iconfont": {
                      "opacity": ".7"
                    }
                  },
                  "a": {
                    "position": "relative",
                    "z-index": "1",
                    "display": "block",
                    ".mbr-iconfont": {
                      "display": "block",
                      "font-size": "25px",
                      "transition": "all 0.3s ease-in-out"
                    }
                  }
                }
              },
              "text-align": "right"
            },
            ".mbr-label": {
              "color": "#ffffff"
            },
            ".mbr-section-title": {
              "color": "#ffffff"
            },
            ".mbr-text": {
              "color": "#ffffff"
            },
            ".mbr-list-title": {
              "color": "#ffffff"
            },
            ".list": {
              "color": "#ffffff"
            }
          },
          "_name": "footer01",
          "_sourceTheme": "integrationm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"footer01 integrationm5\" group=\"Footer\" global once=\"footers\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Label\" name=\"showLabel\" checked>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\">\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\n        <input type=\"checkbox\" title=\"Navigation\" name=\"showNav\" checked>\n        <input type=\"checkbox\" title=\"Navigation Title\" name=\"showNavTitle\" condition=\"showNav\">\n        <input type=\"range\" inline title=\"Navigation Amount\" name=\"listAmount\" min=\"1\" max=\"4\" step=\"1\" value=\"4\" condition=\"showNav\">\n        <input type=\"checkbox\" title=\"Social\" name=\"showSocial\">\n        <input type=\"range\" inline title=\"Amount\" name=\"soc\" min=\"1\" max=\"3\" step=\"1\" value=\"3\" condition=\"showSocial\">\n        <input type=\"checkbox\" title=\"Border\" name=\"showBorder\" checked>\n        <input type=\"color\" title=\"Border Color\" value=\"#ffffff\" name=\"border\" condition=\"showBorder\" selected>\n        <input type=\"checkbox\" title=\"Copyright\" name=\"showCopy\" checked>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/integrationm5/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#171719\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/integrationm5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <header condition=\"bg.type == 'color'\">Gradient</header>\n        <input type=\"checkbox\" title=\"Gradient\" name=\"showGradientBg\" condition=\"bg.type == 'color'\" checked>\n        <input type=\"color\" title=\"Gradient Color\" value=\"#04492e\" name=\"gradientColor_1\" condition=\"showGradientBg && bg.type == 'color'\" selected>\n\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-12 col-lg-11\">\n                <div class=\"content-wrapper\">\n                    <div class=\"row justify-content-center\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n                        <div class=\"col-12 col-lg-6\" mbr-if=\"showLabel || showTitle || showText || showButtons\">\n                            <div class=\"title-wrapper\">\n                                <p class=\"mbr-label card-wrap mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showLabel\" data-app-selector=\".mbr-label\"><a href=\"https://www.google.com/maps/place/?cid=10030005441169209124\" class=\"text-primary\">Ora Construction - Home Remodeling, Masonry &amp; Landscape Design</a></p>\n                                <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .mbr-section-btn, .title-wrapper\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\"><b><a href=\"index.html\" class=\"text-primary\">home remodeling Long Island</a></b></h2>\n                                <div class=\"text-wrapper\">\n                                    <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .text-wrapper\">\n                                        Business Directory is a trusted platform designed to connect companies,\n                                        professionals, and service providers in one place.\n                                    </p>\n                                </div>\n                                <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-white\" href=\"privacy-policy.html\" data-app-placeholder=\"Type Text\"><strong>Privacy Policy</strong></a></div>\n                            </div>\n                        </div>\n                        <div class=\"col-12 col-lg-6\" mbr-if=\"showNav\">\n                            <div class=\"nav-wrapper\">\n                                <div class=\"nav-wrap\">\n                                    <h4 class=\"mbr-list-title mbr-fonts-style\" data-app-selector=\".mbr-list-title\" mbr-theme-style=\"display-4\" mbr-if=\"showNavTitle\">\n                                        <b>Menu</b>\n                                    </h4>\n                                    <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".list, .item-wrap\" data-multiline mbr-article>\n                                        <li class=\"item-wrap\">Address</li>\n                                    </ul>\n                                </div>\n                                <div class=\"nav-wrap\" mbr-if=\"listAmount > 1\">\n                                    <h4 class=\"mbr-list-title mbr-fonts-style\" data-app-selector=\".mbr-list-title\" mbr-theme-style=\"display-4\" mbr-if=\"showNavTitle\">\n                                        <b>Features</b>\n                                    </h4>\n                                    <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".list, .item-wrap\" data-multiline mbr-article>\n                                        <li class=\"item-wrap\">Useful Links</li>\n                                    </ul>\n                                </div>\n                                <div class=\"nav-wrap\" mbr-if=\"listAmount > 2\">\n                                    <h4 class=\"mbr-list-title mbr-fonts-style\" data-app-selector=\".mbr-list-title\" mbr-theme-style=\"display-7\" mbr-if=\"showNavTitle\">\n                                        <b>Clients</b>\n                                    </h4>\n                                    <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".list, .item-wrap\" data-multiline mbr-article>\n                                        <li class=\"item-wrap\">Ora Construction - Home Remodeling, Masonry &amp; Landscape Design\n</li><li class=\"item-wrap\">24 David Drive, Syosset,\n</li><li class=\"item-wrap\">NY 11791\n</li><li class=\"item-wrap\"><b><u>Phone Number:\n</u></b></li><li class=\"item-wrap\">(516) 697-7680</li><li class=\"item-wrap\">\n</li>\n                                    </ul>\n                                </div>\n                                <div class=\"nav-wrap\" mbr-if=\"listAmount > 3\">\n                                    <h4 class=\"mbr-list-title mbr-fonts-style\" data-app-selector=\".mbr-list-title\" mbr-theme-style=\"display-7\" mbr-if=\"showNavTitle\">\n                                        <b>Team</b>\n                                    </h4>\n                                    <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".list, .item-wrap\" data-multiline mbr-article>\n                                        <li class=\"item-wrap\"><a href=\"https://www.google.com/search?q=Syosset%2C+NY\" class=\"text-primary\">Syosset, NY</a>\n</li><li class=\"item-wrap\"><a href=\"https://maps.app.goo.gl/p2RHU3FSxtJUNaCX7\" class=\"text-primary\">The Great Escape Room Long Island</a>\n</li><li class=\"item-wrap\"><a href=\"https://maps.app.goo.gl/MjJuVqKy6fffbhBa9\" class=\"text-primary\">Bounce! Family Entertainment Center</a>\n</li><li class=\"item-wrap\"><a href=\"https://maps.app.goo.gl/NcaPKYrhZz1jBXca6\" class=\"text-primary\">AMF Syosset Lanes</a></li>\n                                    </ul>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"col-12\">\n                            <div class=\"border-wrap\" mbr-if=\"showBorder\"></div>\n                        </div>\n                    </div>\n                    <div class=\"row justify-content-center flex-row-reverse\">\n                        <div class=\"col-12 col-lg-6 card\" mbr-if=\"showSocial\">\n                            <div class=\"social-wrapper\">\n                                <div class=\"social-wrap\">\n                                    <div class=\"soc-item\">\n                                        <a href=\"https://mobiri.se/\">\n                                    <span mbr-icon class=\"mbr-iconfont card-icon socicon socicon-facebook\" data-app-selector=\".card-icon\" style=\"color: rgb(255, 255, 255); fill: rgb(255, 255, 255);\"></span>\n                                        </a>\n                                    </div>\n                                    <div class=\"soc-item\" mbr-if=\"soc > 1\">\n                                        <a href=\"https://mobiri.se/\">\n                                    <span mbr-icon class=\"mbr-iconfont socicon socicon-instagram\" data-app-selector=\".card-icon\" style=\"color: rgb(255, 255, 255); fill: rgb(255, 255, 255);\"></span>\n                                        </a>\n                                    </div>\n                                    <div class=\"soc-item\" mbr-if=\"soc > 2\">\n                                        <a href=\"https://mobiri.se/\">\n                                    <span mbr-icon class=\"mbr-iconfont socicon socicon-linkedin\" data-app-selector=\".card-icon\" style=\"color: rgb(255, 255, 255); fill: rgb(255, 255, 255);\"></span>\n                                        </a>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"col-12 col-lg-6 card\">\n                            <p class=\"mbr-copy mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-copy\" mbr-if=\"showCopy\">\n                                © Copyright 2026 - All Rights Reserved\n                            </p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
