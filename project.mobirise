                "background-image": "url(@fallBackImage)"
              }
            },
            "img": {
              "border-radius": "2rem",
              "margin-bottom": "1rem"
            },
            ".card-wrapper": {
              "border": "3px solid @primaryColor",
              "padding": "2rem",
              "border-radius": "2rem",
              "@media (max-width: 992px)": {
                "margin-bottom": "2rem"
              },
              "@media (max-width: 767px)": {
                "padding": "2rem 1rem"
              }
            },
            ".mbr-section-subtitle": {
              "background": "@primaryColor",
              "color": "#ffffff",
              "width": "fit-content",
              "border-radius": "2rem",
              "padding": "5px 1rem",
              "text-align": "left"
            },
            ".subtitle-wrap": {
              "display": "inline-flex",
              "border-radius": "2rem",
              "padding": "0.5rem",
              "padding-bottom": "0",
              "padding-left": "20px",
              "background": "@secondaryColor",
              "flex-direction": "row",
              "width": "fit-content",
              "align-items": "center",
              "margin-bottom": "2rem",
              ".mbr-iconfont": {
                "padding": "0 15px",
                "padding-bottom": "8px",
                "margin": "0",
                "color": "@primaryColor",
                "font-size": "1.5rem"
              }
            },
            ".mbr-section-title": {
              "color": "#04492e",
              "text-align": "center"
            },
            ".mbr-text, .mbr-section-btn": {
              "color": "#6e6e6e"
            },
            ".mbr-section-subtitle2, .align-wrapper": {
              "color": "#04492e"
            },
            ".mbr-section-maintitle": {
              "text-align": "center",
              "color": "#04492e"
            }
