    "about-us.html": {
      "settings": {
        "title": "About Us",
        "meta_descr": "ORA Construction is a trusted construction company serving homeowners and commercial property owners across Syosset with dependable building and renovation services. With more than two decades of industry experience, the company has established a reputation for delivering high-quality workmanship, practical solutions, and consistent results on projects of varying sizes and complexity. The team combines skilled craftsmanship with hands-on project management to ensure that every project is completed with precision, efficiency, and attention to detail.",
        "header_custom": "",
        "footer_custom": "",
        "html_before": "",
        "order": "4"
      },
