              "gap": "30px 0",
              "margin-bottom": "50px",
              "@media (max-width: 992px)": {
                "margin-bottom": "40px"
              },
              ".nav-wrap": {
                "padding-left": "20px",
                "width": "25%",
                "@media (max-width: 1440px)": {
                  "padding-left": "0",
                  "width": "50%"
                },
                "@media (max-width: 768px)": {
